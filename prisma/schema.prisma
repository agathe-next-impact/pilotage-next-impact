// Schéma Prisma — Pilotage Next Impact

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Snapshot {
  id        Int      @id @default(autoincrement())
  period    String   @unique
  source    String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  linkedinFollowers       Int?
  linkedinImpressions     Int?
  linkedinEngagementRate  Float?
  linkedinDmsQualified    Int?
  linkedinFormLeads       Int?
  linkedinPostsPublished  Int?

  nlSubscribers      Int?
  nlOpenRate         Float?
  nlCtrResource      Float?
  nlUnsubscribeRate  Float?
  nlLeadsMentioning  Int?
  nlEditionNumber    Int?

  seoClicks        Int?
  seoImpressions   Int?
  seoPagesIndexed  Int?
  seoPagesTop10    Int?
  seoAvgPosition   Float?

  geoShareOfVoice    Float?
  geoCitationsCount  Int?
  geoReferralTraffic Int?

  ga4Sessions     Int?
  ga4Users        Int?
  ga4Conversions  Int?

  geoAuditRuns GeoAuditRun[]
}

model GeoAuditRun {
  id       Int      @id @default(autoincrement())
  snapshot Snapshot @relation(fields: [period], references: [period], onDelete: Cascade)
  period   String
  ranAt    DateTime @default(now())
  payload  String

  @@index([period])
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  ip        String
  email     String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
  @@index([email, createdAt])
}

model ContentItem {
  id             Int      @id @default(autoincrement())
  slug           String   @unique
  type           String
  trackKey       String
  plannedFor     DateTime
  status         String   @default("planned")
  /// Sujet planifié (issu du brief)
  subject        String
  /// Sujet final éditable par l'utilisatrice (après revue)
  finalSubject   String?
  /// Brief court de référence
  brief          String
  /// Dernier draft généré par Claude
  draft          String?
  /// Version finale validée et prête à publier (markdown éditable)
  finalBody      String?
  /// URL publique du post une fois publié (LinkedIn URL, lien Substack, URL article)
  publishedUrl   String?
  generatedModel String?
  generatedAt    DateTime?
  validatedAt    DateTime?
  publishedAt    DateTime?
  meta           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  revisions ContentRevision[]
  media     MediaAsset[]

  @@index([type, plannedFor])
  @@index([status])
}

model ContentRevision {
  id        Int         @id @default(autoincrement())
  contentId Int
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  payload   String
  createdAt DateTime    @default(now())

  @@index([contentId, createdAt])
}

model MediaAsset {
  id        Int         @id @default(autoincrement())
  contentId Int
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  /// "image" | "video" | "document"
  kind      String
  /// URL Vercel Blob
  url       String
  filename  String
  size      Int
  mimeType  String
  alt       String?
  caption   String?
  /// Ordre d'affichage dans la galerie
  position  Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([contentId, position])
}

model PlanRevision {
  id            Int       @id @default(autoincrement())
  scope         String
  status        String    @default("pending")
  basedOnPeriod String
  payload       String
  model         String
  createdAt     DateTime  @default(now())
  appliedAt     DateTime?
  rejectedAt    DateTime?

  @@index([scope, status])
}
