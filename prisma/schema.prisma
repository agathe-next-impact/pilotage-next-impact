// Schéma Prisma — Suivi de performances marketing Next Impact
// Saisie hebdomadaire : KPIs + posts LinkedIn + newsletter + actions SEO/GEO.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  ip        String
  email     String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
  @@index([email, createdAt])
}

/// Une semaine de suivi marketing — un seul rapport par lundi.
model WeekReport {
  id        Int      @id @default(autoincrement())
  /// Lundi 00:00 UTC de la semaine
  weekStart DateTime @unique
  /// Synthèse libre / observations sur la semaine
  notes     String?

  // KPIs globaux fin de semaine ----------
  linkedinFollowers      Int?
  newsletterSubscribers  Int?
  seoClicks              Int?
  seoImpressions         Int?
  geoShareOfVoice        Float?

  posts        WeekPost[]
  newsletter   WeekNewsletter?
  seoGeoActions SeoGeoAction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// 0..N posts LinkedIn par semaine.
model WeekPost {
  id           Int        @id @default(autoincrement())
  weekReportId Int
  weekReport   WeekReport @relation(fields: [weekReportId], references: [id], onDelete: Cascade)

  publishedAt  DateTime
  subject      String
  content      String     // markdown libre
  url          String?    // URL post-publication LinkedIn

  // Métriques saisies manuellement après publication
  impressions  Int?
  reactions    Int?
  comments     Int?
  shares       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weekReportId])
}

/// 0 ou 1 édition newsletter par semaine.
model WeekNewsletter {
  id           Int        @id @default(autoincrement())
  weekReportId Int        @unique
  weekReport   WeekReport @relation(fields: [weekReportId], references: [id], onDelete: Cascade)

  publishedAt  DateTime
  subject      String
  content      String     // markdown libre
  url          String?    // URL Substack

  // Métriques
  emailSends   Int?
  emailOpens   Int?
  emailClicks  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// 0..N actions SEO ou GEO par semaine (audit, page, backlink, citation IA…).
model SeoGeoAction {
  id           Int        @id @default(autoincrement())
  weekReportId Int
  weekReport   WeekReport @relation(fields: [weekReportId], references: [id], onDelete: Cascade)

  /// "seo-page" | "seo-backlink" | "seo-audit" | "geo-citation" | "geo-prompt" | "autre"
  type         String
  description  String     // texte libre, ce qui a été fait
  result       String?    // texte libre, résultat / suite

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([weekReportId])
}
