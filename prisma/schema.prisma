// Schéma Prisma — Pilotage Next Impact

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Snapshot {
  id        Int      @id @default(autoincrement())
  period    String   @unique
  source    String   @default("manual")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  linkedinFollowers       Int?
  linkedinImpressions     Int?
  linkedinEngagementRate  Float?
  linkedinDmsQualified    Int?
  linkedinFormLeads       Int?
  linkedinPostsPublished  Int?

  nlSubscribers      Int?
  nlOpenRate         Float?
  nlCtrResource      Float?
  nlUnsubscribeRate  Float?
  nlLeadsMentioning  Int?
  nlEditionNumber    Int?

  seoClicks        Int?
  seoImpressions   Int?
  seoPagesIndexed  Int?
  seoPagesTop10    Int?
  seoAvgPosition   Float?

  geoShareOfVoice    Float?
  geoCitationsCount  Int?
  geoReferralTraffic Int?

  ga4Sessions     Int?
  ga4Users        Int?
  ga4Conversions  Int?

  geoAuditRuns GeoAuditRun[]
}

model GeoAuditRun {
  id       Int      @id @default(autoincrement())
  snapshot Snapshot @relation(fields: [period], references: [period], onDelete: Cascade)
  period   String
  ranAt    DateTime @default(now())
  payload  String

  @@index([period])
}

model LoginAttempt {
  id        Int      @id @default(autoincrement())
  ip        String
  email     String
  success   Boolean
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
  @@index([email, createdAt])
}

model ContentItem {
  id             Int      @id @default(autoincrement())
  slug           String   @unique
  type           String
  trackKey       String
  plannedFor     DateTime
  status         String   @default("planned")
  subject        String
  finalSubject   String?
  brief          String
  draft          String?
  finalBody      String?
  publishedUrl   String?
  generatedModel String?
  generatedAt    DateTime?
  validatedAt    DateTime?
  publishedAt    DateTime?
  meta           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  revisions ContentRevision[]
  media     MediaAsset[]

  @@index([type, plannedFor])
  @@index([status])
}

model ContentRevision {
  id        Int         @id @default(autoincrement())
  contentId Int
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  payload   String
  createdAt DateTime    @default(now())

  @@index([contentId, createdAt])
}

model MediaAsset {
  id        Int         @id @default(autoincrement())
  contentId Int
  content   ContentItem @relation(fields: [contentId], references: [id], onDelete: Cascade)
  kind      String
  url       String
  filename  String
  size      Int
  mimeType  String
  alt       String?
  caption   String?
  position  Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([contentId, position])
}

model PlanRevision {
  id            Int       @id @default(autoincrement())
  scope         String
  status        String    @default("pending")
  basedOnPeriod String
  payload       String
  model         String
  createdAt     DateTime  @default(now())
  appliedAt     DateTime?
  rejectedAt    DateTime?
  /// Si la révision est déclenchée par un input chat utilisateur, on lie au contexte
  contextId     Int?
  context       PlanningContext? @relation(fields: [contextId], references: [id], onDelete: SetNull)

  @@index([scope, status])
  @@index([contextId])
}

/**
 * Facteurs contextuels qui impactent le planning hebdo.
 * Saisis par l'utilisateur via chat ("j'ai un client tout la semaine prochaine"),
 * ou détectés automatiquement (pic perf, KPI dérive, événement externe).
 */
model PlanningContext {
  id            Int       @id @default(autoincrement())
  /// Lundi de la semaine impactée (00:00 UTC). Null si impact global / multi-semaines.
  weekStart     DateTime?
  /// "user_chat" | "kpi_signal" | "external_event" | "perf_learning"
  source        String
  /// Texte libre saisi par l'utilisatrice (si source=user_chat)
  rawInput      String?
  /// Synthèse Claude du contexte
  digest        String
  /// Slugs ContentItem impactés (JSON array)
  affectedSlugs String?
  /// "pending" | "applied" | "ignored" | "stale"
  status        String    @default("pending")
  resolvedAt    DateTime?
  createdAt     DateTime  @default(now())

  revisions PlanRevision[]

  @@index([weekStart, status])
  @@index([createdAt])
}
