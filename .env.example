# =============================================================================
# Pilotage Next Impact — Variables d'environnement
# =============================================================================

# ── Base de données ─────────────────────────────────────────────────────────
# Dev local : SQLite (rapide, zéro config)
DATABASE_URL="file:./pilotage.db"
# Prod : Postgres (Neon recommandé — https://neon.tech)
# DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/pilotage?sslmode=require"

# ── Auth ────────────────────────────────────────────────────────────────────
ADMIN_EMAIL="agathe.karinthi.martin@gmail.com"
ADMIN_PASSWORD="change-me-now"
# 32 caractères minimum — générer : openssl rand -base64 32
SESSION_PASSWORD="replace-with-32-chars-random-secret-please"

# ── Cron Vercel ─────────────────────────────────────────────────────────────
# Header attendu par /api/kpi/sync-* : Authorization: Bearer ${CRON_SECRET}
# Générer : openssl rand -hex 32
CRON_SECRET=""

# ── Google Search Console ───────────────────────────────────────────────────
# 1. Créer un service account sur Google Cloud Console
# 2. Donner accès en lecture sur la propriété GSC
# 3. Télécharger la clé JSON, copier client_email + private_key ci-dessous
GSC_CLIENT_EMAIL=""
GSC_PRIVATE_KEY=""
# Format : sc-domain:next-impact.digital  (ou https://next-impact.digital/)
GSC_SITE_URL="sc-domain:next-impact.digital"

# ── Google Analytics 4 ──────────────────────────────────────────────────────
# Le service account ci-dessus doit être ajouté en lecture sur la propriété GA4
GA4_PROPERTY_ID=""

# ── Anthropic — génération de contenu et ajustement de plan ────────────────
# Modèles utilisés : claude-opus-4-7 (long format) et claude-sonnet-4-6 (LinkedIn)
ANTHROPIC_API_KEY=""

# ── Audit GEO (optionnel) ───────────────────────────────────────────────────
OPENAI_API_KEY=""
PERPLEXITY_API_KEY=""

# ── Site cible (pour audit GEO) ─────────────────────────────────────────────
TARGET_DOMAIN="next-impact.digital"
TARGET_BRAND_TERMS="next impact,karinthi"
