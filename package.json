{
  "name": "pilotage-next-impact",
  "version": "1.0.0",
  "private": true,
  "description": "Tableau de bord standalone — pilotage de la communication digitale Next Impact (LinkedIn, Newsletter, SEO, GEO).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "prisma generate && prisma db push --skip-generate --accept-data-loss && tsx prisma/seed.ts && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google-analytics/data": "^4.12.0",
    "@prisma/client": "^6.0.0",
    "googleapis": "^144.0.0",
    "iron-session": "^8.0.4",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.13.0",
    "zod": "^3.23.8",
    "@anthropic-ai/sdk": "^0.30.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
